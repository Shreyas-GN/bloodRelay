# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (production) — omit to fall back to local SQLite
DATABASE_URL=postgresql://user:password@host:5432/bloodrelay

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# ── Matching Engine ───────────────────────────────────────────────────────────
MATCHING_ENGINE_URL=http://matching-engine:9000
